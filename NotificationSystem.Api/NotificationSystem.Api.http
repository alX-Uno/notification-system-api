@baseUrl = http://localhost:5185

### Login
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "Username": "admin",
  "Password": "Password123$"
}

### Crear orden
POST {{baseUrl}}/api/orders
Content-Type: application/json
Authorization: Bearer {{login.response.body.token}}

{
  "customerName": "Funciona",
  "totalAmount": 50.99
}